---
interface Comment {
  id: number;
  anchor_text: string;
  author_name: string;
  body: string;
  range_start: number;
  range_end: number;
  context_html: string;
}

interface Props {
  comments: Comment[];
  slug: string;
  locale: string;
}

const { comments, slug, locale } = Astro.props;
---

<div
  id="inline-comments-data"
  style="display:none"
  data-comments={JSON.stringify(comments)}
  data-slug={slug}
  data-locale={locale}
></div>

<div id="inline-comment-cards"></div>

<style>
  .inline-comment-card {
    position: absolute;
    right: -280px;
    width: 260px;
    background: #fff;
    border: 1px solid #e2e2e2;
    border-radius: 6px;
    padding: 0.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    font-size: 0.8rem;
    line-height: 1.5;
    z-index: 10;
  }

  .inline-comment-card::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 12px;
    border: 4px solid transparent;
    border-right-color: #e2e2e2;
  }

  .inline-comment-card .ic-meta {
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.25rem;
  }

  .inline-comment-card .ic-anchor {
    font-style: italic;
    color: #666;
    font-size: 0.75rem;
    margin-bottom: 0.4rem;
    border-left: 2px solid #f59e0b;
    padding-left: 0.4rem;
  }

  .inline-comment-card .ic-body {
    color: #333;
  }

  .inline-comment-card .ic-actions {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .inline-comment-card .ic-btn {
    padding: 0.2rem 0.6rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .inline-comment-card .ic-btn-approve { background: #22c55e; color: #fff; }
  .inline-comment-card .ic-btn-reject  { background: #ef4444; color: #fff; }

  /* Highlight applied to the anchored text in the article */
  :global(.ic-highlight) {
    background: #fef3c7;
    border-radius: 2px;
    outline: 2px solid #f59e0b;
    outline-offset: 1px;
  }

  /* Narrow viewports: cards stack below article */
  @media (max-width: 1000px) {
    .inline-comment-card {
      position: static;
      width: 100%;
      margin-bottom: 0.75rem;
    }

    .inline-comment-card::before {
      display: none;
    }
  }
</style>

<script>
  (function () {
    const dataEl = document.getElementById('inline-comments-data');
    if (!dataEl) return;

    const comments = JSON.parse(dataEl.dataset.comments || '[]') as Array<{
      id: number;
      anchor_text: string;
      author_name: string;
      body: string;
      range_start: number;
      range_end: number;
      context_html: string;
    }>;

    if (comments.length === 0) return;

    const article = document.getElementById('article-content');
    if (!article) return;

    // Make the article wrapper position:relative so absolute cards work
    const articleParent = article.parentElement;
    if (articleParent) articleParent.style.position = 'relative';

    const cardContainer = document.getElementById('inline-comment-cards');

    for (const comment of comments) {
      const anchorSpan = highlightRange(article, comment.range_start, comment.range_end);
      if (!anchorSpan) continue;

      anchorSpan.classList.add('ic-highlight');

      const card = buildCard(comment);

      // Position card vertically aligned with the highlight on wide viewports
      const isWide = window.innerWidth > 1000;
      if (isWide) {
        const articleRect = article.getBoundingClientRect();
        const spanRect = anchorSpan.getBoundingClientRect();
        const topOffset = spanRect.top - articleRect.top + window.scrollY;
        card.style.top = `${topOffset}px`;
      }

      articleParent?.appendChild(card);

      // Re-position on resize
      window.addEventListener('resize', () => {
        if (window.innerWidth > 1000) {
          const articleRect = article.getBoundingClientRect();
          const spanRect = anchorSpan.getBoundingClientRect();
          const topOffset = spanRect.top - articleRect.top + window.scrollY;
          card.style.top = `${topOffset}px`;
        } else {
          card.style.top = '';
        }
      });
    }

    /**
     * Walk the text nodes of `root`, find the range [start, end) in the
     * concatenated text content, and wrap those characters in a <span>.
     * This is the inverse of the recording logic in comment-widget.js which uses
     * article.textContent.indexOf(text) to derive range_start/range_end.
     */
    function highlightRange(root: Element, start: number, end: number): HTMLElement | null {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      let offset = 0;
      const parts: { node: Text; localStart: number; localEnd: number }[] = [];

      let node: Text | null;
      while ((node = walker.nextNode() as Text | null)) {
        const len = node.nodeValue?.length ?? 0;
        const nodeStart = offset;
        const nodeEnd = offset + len;

        if (nodeEnd > start && nodeStart < end) {
          parts.push({
            node,
            localStart: Math.max(0, start - nodeStart),
            localEnd: Math.min(len, end - nodeStart),
          });
        }

        offset += len;
        if (offset >= end) break;
      }

      if (parts.length === 0) return null;

      const span = document.createElement('span');

      // Handle single-node case (most common)
      if (parts.length === 1) {
        const { node: textNode, localStart, localEnd } = parts[0];
        const before = textNode.nodeValue!.slice(0, localStart);
        const highlighted = textNode.nodeValue!.slice(localStart, localEnd);
        const after = textNode.nodeValue!.slice(localEnd);

        span.textContent = highlighted;
        const parent = textNode.parentNode!;
        parent.insertBefore(document.createTextNode(before), textNode);
        parent.insertBefore(span, textNode);
        parent.insertBefore(document.createTextNode(after), textNode);
        parent.removeChild(textNode);
        return span;
      }

      // Multi-node: each part stays in its original parent element.
      // Collect part spans so we can apply the highlight class to all of them,
      // then return the first for card-positioning purposes.
      const partSpans: HTMLElement[] = [];
      for (let i = 0; i < parts.length; i++) {
        const { node: textNode, localStart, localEnd } = parts[i];
        const highlighted = textNode.nodeValue!.slice(localStart, localEnd);
        const partSpan = document.createElement('span');
        partSpan.textContent = highlighted;

        const before = textNode.nodeValue!.slice(0, localStart);
        const after = textNode.nodeValue!.slice(localEnd);
        const parent = textNode.parentNode!;

        if (before) parent.insertBefore(document.createTextNode(before), textNode);
        parent.insertBefore(partSpan, textNode);
        if (after) parent.insertBefore(document.createTextNode(after), textNode);
        parent.removeChild(textNode);
        partSpans.push(partSpan);
      }

      // Apply highlight class to every part; caller will also add it to the first (harmless).
      for (const ps of partSpans) ps.classList.add('ic-highlight');
      return partSpans[0];
    }

    // Safely strip HTML tags using DOMParser to avoid regex pitfalls with attributes containing >.
    function stripTags(html: string): string {
      try {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        return doc.body.textContent ?? '';
      } catch {
        return '';
      }
    }

    function buildCard(comment: { id: number; anchor_text: string; author_name: string; body: string; context_html: string }): HTMLElement {
      const card = document.createElement('div');
      card.className = 'inline-comment-card';
      card.dataset.commentId = String(comment.id);

      const meta = document.createElement('div');
      meta.className = 'ic-meta';
      meta.textContent = comment.author_name;

      // Show just the highlighted text (anchor_text), capped at 150 chars.
      const display = comment.anchor_text.length > 150
        ? comment.anchor_text.slice(0, 150) + '…'
        : comment.anchor_text;
      const anchor = document.createElement('div');
      anchor.className = 'ic-anchor';
      anchor.textContent = `"${display}"`;

      const body = document.createElement('div');
      body.className = 'ic-body';
      body.textContent = comment.body;

      const actions = document.createElement('div');
      actions.className = 'ic-actions';

      const approveBtn = document.createElement('button');
      approveBtn.className = 'ic-btn ic-btn-approve';
      approveBtn.textContent = 'Approve';
      approveBtn.addEventListener('click', () => moderateComment(comment.id, 'approved', card));

      const rejectBtn = document.createElement('button');
      rejectBtn.className = 'ic-btn ic-btn-reject';
      rejectBtn.textContent = 'Reject';
      rejectBtn.addEventListener('click', () => moderateComment(comment.id, 'rejected', card));

      actions.appendChild(approveBtn);
      actions.appendChild(rejectBtn);
      card.appendChild(meta);
      card.appendChild(anchor);
      card.appendChild(body);
      card.appendChild(actions);

      return card;
    }

    async function moderateComment(id: number, status: 'approved' | 'rejected', card: HTMLElement) {
      try {
        const res = await fetch(`/api/comments/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status }),
        });
        if (res.ok) {
          card.style.opacity = '0.4';
          card.style.pointerEvents = 'none';
          const label = document.createElement('div');
          label.style.cssText = 'font-size:0.75rem;color:#555;margin-top:0.4rem;font-style:italic;';
          label.textContent = status === 'approved' ? 'Approved' : 'Rejected';
          card.appendChild(label);
        }
      } catch {
        // ignore
      }
    }
  })();
</script>
