---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CommentBubble from '../../components/CommentBubble.astro';
import InlineComments from '../../components/InlineComments.astro';
import { t, locales } from '../../i18n/utils';
import { getDb } from '../../lib/db';
import type { Locale } from '../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales) {
    const notes = await getCollection(locale);
    for (const note of notes) {
      paths.push({ params: { locale, slug: note.slug } });
    }
  }
  return paths;
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };

const entry = await getEntry(locale, slug);
if (!entry) {
  return Astro.redirect(`/${locale}`, 302);
}

const { Content, remarkPluginFrontmatter } = await entry.render();
const readingTime = remarkPluginFrontmatter?.readingTime as string | undefined;

const isAdmin = Astro.locals.isAdmin;

// Load approved comments for all visitors
let approvedComments: Array<{
  id: number;
  anchor_text: string;
  author_name: string;
  body: string;
  created_at: string;
  context_html: string;
}> = [];

// Load pending comments only for admin
let pendingComments: Array<{
  id: number;
  anchor_text: string;
  author_name: string;
  body: string;
  range_start: number;
  range_end: number;
  context_html: string;
}> = [];

try {
  const db = getDb();
  approvedComments = db
    .prepare(
      `SELECT id, anchor_text, author_name, body, created_at, context_html
       FROM comments
       WHERE page_slug = ? AND locale = ? AND status = 'approved'
       ORDER BY created_at ASC`
    )
    .all(slug, locale) as typeof approvedComments;

  if (isAdmin) {
    pendingComments = db
      .prepare(
        `SELECT id, anchor_text, author_name, body, range_start, range_end, context_html
         FROM comments
         WHERE page_slug = ? AND locale = ? AND status = 'pending'
         ORDER BY created_at ASC`
      )
      .all(slug, locale) as typeof pendingComments;
  }
} catch {
  // DB unavailable
}
---
<Layout title={entry.data.title} description={entry.data.description} locale={locale} slug={slug}>
  <article id="article-content">
    <header style="margin-bottom:1.5rem;">
      <h1>{entry.data.title}</h1>
      <p class="muted">
        {t('note.publishedOn', locale)} {entry.data.pubDate.toLocaleDateString()}
        {readingTime && <span> · {readingTime} {t('note.readingTime', locale)}</span>}
      </p>
      {entry.data.tags.length > 0 && (
        <div style="margin-top:0.5rem;">
          {entry.data.tags.map((tag) => (
            <a href={`/${locale}/tags/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>

  {approvedComments.length > 0 && (
    <section style="margin-top:3rem;">
      <h2>{t('comment.heading', locale)}</h2>
      {approvedComments.map((c) => (
        <CommentBubble
          id={c.id}
          anchorText={c.anchor_text}
          authorName={c.author_name}
          body={c.body}
          createdAt={c.created_at}
          contextHtml={c.context_html}
        />
      ))}
    </section>
  )}

  {isAdmin && pendingComments.length > 0 && (
    <InlineComments comments={pendingComments} slug={slug} locale={locale} />
  )}

  {isAdmin && (
    <div style="margin-top:2rem;padding:0.75rem 1rem;background:#fef9ec;border:1px solid #f59e0b;border-radius:6px;font-size:0.85rem;">
      Admin session active &mdash;
      <button id="admin-logout-btn" style="background:none;border:none;color:#2563eb;cursor:pointer;font-size:0.85rem;padding:0;text-decoration:underline;">Log out</button>
    </div>
  )}

  <nav style="margin-top:3rem; border-top:1px solid var(--color-border); padding-top:1rem;">
    <a href={`/${locale}`}>{t('note.backToHome', locale)}</a>
  </nav>
</Layout>

<script src="/scripts/visit-tracker.js" is:inline></script>
<script src="/scripts/comment-widget.js" is:inline></script>
<script src="/scripts/bookmark-widget.js" is:inline></script>
<script src="/scripts/link-counter.js" is:inline></script>

<script>
  const logoutBtn = document.getElementById('admin-logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      await fetch('/api/auth/sign-out', { method: 'POST', credentials: 'same-origin' });
      window.location.href = '/';
    });
  }
</script>

<style>
  .prose { line-height: 1.8; }
  .prose :global(h2), .prose :global(h3) { margin-top: 2em; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5em; margin-bottom: 1em; }
  .prose :global(li) { margin-bottom: 0.25em; }
  .prose :global(blockquote) {
    border-left: 3px solid #ccc;
    padding-left: 1em;
    color: #555;
    font-style: italic;
    margin: 1em 0;
  }
</style>
